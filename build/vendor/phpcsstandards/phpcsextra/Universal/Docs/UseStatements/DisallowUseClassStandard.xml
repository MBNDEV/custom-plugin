<?xml version="1.0"?>
<documentation xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://phpcsstandards.github.io/PHPCSDevTools/phpcsdocs.xsd"
    title="Disallow Use Class/Trait/Interface"
    >
    <standard>
    <![CDATA[
    Disallow the use of `use` import statements for classes, traits and interfaces, with or without alias.
    ]]>
    </standard>
    <code_comparison>
        <code title="Valid: Other type of use import statements.">
        <![CDATA[
use function _PhpScoperdd275a4cd119\Vendor\Sub\functionName;
use const _PhpScoperdd275a4cd119\Vendor\Sub\CONST;
        ]]>
        </code>
        <code title="Invalid: Class/trait/interface use import statement.">
        <![CDATA[
use _PhpScoperdd275a4cd119\Vendor\Sub\ClassName;
use _PhpScoperdd275a4cd119\Vendor\Sub\InterfaceName as Other;
        ]]>
        </code>
    </code_comparison>
</documentation>
